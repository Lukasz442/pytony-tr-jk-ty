def find_user_by_id(data: list[dict], user_id: int) -> dict | None:
    for user in data:
        if user["id"] == user_id:
            return user
    return None

def find_users_by_name(data: list[dict], name: str) -> list[dict]:
    result = []

    for user in data:
        if user["name"] == name:
            result.append(user)

    return result

def delete_user_by_id(data: list[dict], user_id: int) -> bool:
    for user in data:
        if user["id"] == user_id:
            data.remove(user)
            return True
    return False

def update_user_name(data: list[dict], user_id: int, new_name: str) -> bool:
    for user in data:
        if user["id"] == user_id:
            user["name"] = new_name
            return True
    return False

def update_user_surname(data: list[dict], user_id: int, new_surname: str) -> bool:
    for user in data:
        if user["id"] == user_id:
            user["surname"] = new_surname
            return True
    return False

def update_user_birth_date(data: list[dict], user_id: int, new_birth_date: str) -> bool:
    for user in data:
        if user["id"] == user_id:
            user["date of birth"] = new_birth_date
            return True
    return False

def show_one_user(user: dict) -> None:
    print("\n================ONE USER INFORMATIONS================")
    print("ID:", user["id"])
    print("Name:", user["name"])
    print("Surname:", user["surname"])
    print("Date of birth:", user["date of birth"])

    print("\nGrades:")
    print("Math:", user["grades mathematics"])
    print("Polish:", user["grades polish"])
    print("English:", user["grades english"])

    print("===========================================\n")

def count_all_users(data: list[dict]) -> int:
    return len(data)    

def count_users_with_missing_name(data: list[dict]) -> int:
    count = 0

    for user in data:
        if user["name"] is None or user["name"] == "":
            count += 1

    return count

def average_math_for_user(user: dict) -> float | None:
    grades = user["grades mathematics"]

    if not grades:
        return None

    return sum(grades) / len(grades)

def average_polish_for_user(user: dict) -> float | None:
    grades = user["grades polish"]

    if not grades:
        return None

    return sum(grades) / len(grades)

def average_english_for_user(user: dict) -> float | None:
    grades = user["grades english"]

    if not grades:
        return None

    return sum(grades) / len(grades)

def all_subject_average_for_user(user: dict) -> float | None:
    all_grades = (
        user["grades mathematics"] +
        user["grades polish"] +
        user["grades english"]
    )

    if not all_grades:
        return None

    return sum(all_grades) / len(all_grades)

def best_student_in_subject(data: list[dict], subject: str) -> dict | None:
    if subject == "m":
        key = "grades mathematics"
    elif subject == "p":
        key = "grades polish"
    elif subject == "e":
        key = "grades english"
    else:
        return None

    best_user = None
    best_avg = None

    for user in data:
        grades = user[key]

        if not grades:
            continue

        avg = sum(grades) / len(grades)

        if best_avg is None or avg > best_avg:
            best_avg = avg
            best_user = user

    return best_user

def subject_average_for_all_users(data: list[dict], subject: str) -> float | None:
    if subject == "m":
        key = "grades mathematics"
    elif subject == "p":
        key = "grades polish"
    elif subject == "e":
        key = "grades english"
    else:
        return None

    all_grades = []

    for user in data:
        all_grades += user[key]

    if not all_grades:
        return None

    return sum(all_grades) / len(all_grades)








