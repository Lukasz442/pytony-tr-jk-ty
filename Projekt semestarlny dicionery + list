from random import randint
def is_name_taken(data: list[dict], name: str, surname: str) -> bool:
    for user in data:
        if user["name"] == name and user["surname"] == surname:
            return True
    return False

def generate_unique_id(data: list[dict]) -> int:
    lst_id = []
    for user in data:
        lst_id.append(user.get("id"))
    new_id = randint(1, 1000000)
    while new_id in lst_id:
        new_id = randint(1, 1000000)
    return new_id

def add_new_user(data: list[dict]) -> dict | None:
    name = input("Enter name: ")
    surname = input("Enter surname: ")

    if is_name_taken(data, name, surname):
        print("User already exists")
        return None

    return {
        "id": generate_unique_id(data),
        "name": name,
        "surname": surname,
        "date of birth": input("date of birth: "),
        "grades mathematics": [],
        "grades polish": [],
        "grades english": []
    }
    
def add_or_remove_grades(data: list[dict]) -> None:
